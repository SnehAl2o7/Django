# Django settings
SECRET_KEY=your-django-production-secret-key
DEBUG=False
ALLOWED_HOSTS=your-app.onrender.com,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com

# Database Connection (Supabase PostgreSQL Connection URI)
# Find this in Supabase: Settings -> Database -> Connection string -> URI
DATABASE_URL=postgres://postgres.xxxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Optional: Supabase S3-compatible Storage (for persistent item image uploads)
# Set these if you want to store uploads on Supabase Storage rather than Render's ephemeral disk.
# 1. Create a public bucket in Supabase called "marketplace-media"
# 2. Set the variables below:
# AWS_ACCESS_KEY_ID=your-supabase-s3-access-key-id
# AWS_SECRET_ACCESS_KEY=your-supabase-s3-secret-access-key
# AWS_STORAGE_BUCKET_NAME=marketplace-media
# AWS_S3_ENDPOINT_URL=https://xxxxxx.supabase.co/storage/v1/s3
# AWS_S3_REGION_NAME=us-east-1
